# EvidenceIQ Environment Configuration
# Copy this file to .env and fill in your values

# ── Required Settings ──────────────────────────────────────────

# JWT Secret Key - Generate with: openssl rand -hex 32
# CRITICAL: Keep this secret! Used for token signing.
SECRET_KEY=your-super-secret-key-change-this-in-production

# ── Application Settings ───────────────────────────────────────

# Environment: development | staging | production
APP_ENV=development

# Debug mode (disable in production)
DEBUG=false

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Security Settings ──────────────────────────────────────────

# Token expiration in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Refresh token expiration in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# Minimum password length
PASSWORD_MIN_LENGTH=8

# ── Database Settings ──────────────────────────────────────────

# SQLite (default for development)
DATABASE_URL=sqlite:///./evidenceiq.db

# PostgreSQL (production) - Uncomment to use
# DATABASE_URL=postgresql://evidenceiq:password@localhost/evidenceiq

# ── Storage Settings ───────────────────────────────────────────

# Root path for file storage
STORAGE_ROOT=./storage

# Maximum file upload size in MB
MAX_FILE_SIZE_MB=500

# ── CORS Settings ────────────────────────────────────────────────

# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── AI / Ollama Settings ───────────────────────────────────────

# Ollama API base URL
OLLAMA_BASE_URL=http://localhost:11434

# Default vision model for processing
VISION_MODEL_DEFAULT=llava

# Available vision models (comma-separated)
AVAILABLE_VISION_MODELS=llava,bakllava,moondream

# LLM for metadata summarization
LLM_MODEL=mistral

# ── Vector Store Settings ──────────────────────────────────────

# ChromaDB persistent storage path
CHROMA_DB_PATH=./chromadb_data

# CLIP model for image embeddings
EMBEDDING_MODEL=sentence-transformers/clip-ViT-B-32

# ── Processing Settings ────────────────────────────────────────

# Extract video frames every N seconds
VIDEO_FRAME_INTERVAL_SECONDS=1

# Maximum thumbnail dimension in pixels
THUMBNAIL_MAX_SIZE=512

# Enable PII scrubbing from metadata
ENABLE_PII_SCRUBBING=true

# ── Rate Limiting ────────────────────────────────────────────────

# Requests per minute per user
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ── Docker Compose Overrides ───────────────────────────────────
# These are only used when running via docker-compose

# Database password (for PostgreSQL mode)
# DB_PASSWORD=change-me-in-production

# Host port mapping
# HOST_API_PORT=8000
# HOST_OLLAMA_PORT=11434
