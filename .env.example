# EvidenceIQ environment configuration
# Copy to .env for local development. Do not commit .env.

# Required for signed JWTs. Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-64-hex-character-random-value

# Application
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
ENABLE_API_DOCS=false

# Security
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_MIN_LENGTH=8

# Database
DATABASE_URL=sqlite:///./evidenceiq.db

# Storage
STORAGE_ROOT=./storage
MAX_FILE_SIZE_MB=500

# CORS: comma-separated browser origins allowed to call the API.
# Production must use explicit HTTPS origins and must not use "*".
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Local AI / Ollama
OLLAMA_BASE_URL=http://localhost:11434
VISION_MODEL_DEFAULT=llava
AVAILABLE_VISION_MODELS=llava,bakllava,moondream
LLM_MODEL=mistral

# Vector store
CHROMA_DB_PATH=./chromadb_data
EMBEDDING_MODEL=sentence-transformers/clip-ViT-B-32
ANONYMIZED_TELEMETRY=False

# Processing
VIDEO_FRAME_INTERVAL_SECONDS=1
THUMBNAIL_MAX_SIZE=512
ENABLE_PII_SCRUBBING=true

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Optional Docker Compose overrides
# HOST_API_PORT=8000
# HOST_OLLAMA_PORT=11434
